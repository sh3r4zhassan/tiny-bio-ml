/*
 * TinyBioML Auto-Generated Firmware
 * Model: {{ model_name }}
 * Board: {{ board_name }}
 * Pin: {{ pin }} ({{ pin_mode }})
 * Sample Rate: {{ sample_rate_ms }}ms
 *
 * Generated by TinyBioML Platform — https://tinybioml.org
 * DO NOT EDIT — regenerate from the platform if you need changes.
 */

#include <TensorFlowLite.h>
#include <tensorflow/lite/micro/all_ops_resolver.h>
#include <tensorflow/lite/micro/micro_interpreter.h>
#include <tensorflow/lite/schema/schema_generated.h>

#include "model_data.h"

// --- Configuration ---
#define SENSOR_PIN       {{ pin }}
#define SAMPLE_RATE_MS   {{ sample_rate_ms }}
#define INPUT_SIZE       {{ input_size }}
#define NUM_CLASSES      {{ num_classes }}

// --- TFLite Micro Globals ---
namespace {
  const tflite::Model* model = nullptr;
  tflite::MicroInterpreter* interpreter = nullptr;
  TfLiteTensor* input_tensor = nullptr;
  TfLiteTensor* output_tensor = nullptr;

  // Arena size — adjust if you get OOM errors
  // Rule of thumb: 2-5x model size
  constexpr int kTensorArenaSize = 8 * 1024;
  uint8_t tensor_arena[kTensorArenaSize];
}

// --- Circular buffer for sensor readings ---
float sensor_buffer[INPUT_SIZE];
int buffer_index = 0;
bool buffer_full = false;

// --- Setup ---
void setup() {
  Serial.begin(115200);
  while (!Serial) { delay(10); }

  Serial.println("=== TinyBioML Firmware ===");
  Serial.println("Model: {{ model_name }}");
  Serial.println("Pin: {{ pin }} ({{ pin_mode }})");
  Serial.println("Initializing...");

  {% if pin_mode == "analog" %}
  // Analog pin — no special setup needed
  pinMode({{ pin }}, INPUT);
  {% elif pin_mode == "digital" %}
  pinMode({{ pin }}, INPUT);
  {% elif pin_mode == "i2c" %}
  Wire.begin();
  {% endif %}

  // Load the TFLite model
  model = tflite::GetModel(model_data);
  if (model->version() != TFLITE_SCHEMA_VERSION) {
    Serial.println("ERROR: Model schema version mismatch!");
    Serial.print("Expected: "); Serial.println(TFLITE_SCHEMA_VERSION);
    Serial.print("Got: "); Serial.println(model->version());
    while (1) { delay(1000); }
  }

  // Set up the resolver (includes all ops — you can slim this down later)
  static tflite::AllOpsResolver resolver;

  // Build the interpreter
  static tflite::MicroInterpreter static_interpreter(
    model, resolver, tensor_arena, kTensorArenaSize);
  interpreter = &static_interpreter;

  // Allocate tensors
  TfLiteStatus allocate_status = interpreter->AllocateTensors();
  if (allocate_status != kTfLiteOk) {
    Serial.println("ERROR: AllocateTensors() failed!");
    Serial.print("Arena size: "); Serial.print(kTensorArenaSize);
    Serial.println(" bytes — try increasing kTensorArenaSize");
    while (1) { delay(1000); }
  }

  input_tensor = interpreter->input(0);
  output_tensor = interpreter->output(0);

  // Print tensor info
  Serial.print("Input shape: [");
  for (int i = 0; i < input_tensor->dims->size; i++) {
    Serial.print(input_tensor->dims->data[i]);
    if (i < input_tensor->dims->size - 1) Serial.print(", ");
  }
  Serial.println("]");

  Serial.print("Arena used: ");
  Serial.print(interpreter->arena_used_bytes());
  Serial.println(" bytes");

  Serial.println("Ready! Collecting data...");
  Serial.println("---");

  // Initialize buffer
  memset(sensor_buffer, 0, sizeof(sensor_buffer));
}

// --- Main Loop ---
void loop() {
  // Read sensor
  {% if pin_mode == "analog" %}
  int raw_value = analogRead({{ pin }});
  float normalized = raw_value / 1023.0;  // Normalize to 0-1
  {% elif pin_mode == "digital" %}
  float normalized = digitalRead({{ pin }}) ? 1.0 : 0.0;
  {% else %}
  float normalized = 0.0;  // Placeholder for I2C — customize per sensor
  {% endif %}

  // Fill circular buffer
  sensor_buffer[buffer_index] = normalized;
  buffer_index++;

  if (buffer_index >= INPUT_SIZE) {
    buffer_full = true;
    buffer_index = 0;
  }

  // Run inference when buffer is full
  if (buffer_full) {
    // Copy buffer to input tensor
    for (int i = 0; i < INPUT_SIZE; i++) {
      // Read from the circular buffer in order
      int idx = (buffer_index + i) % INPUT_SIZE;
      input_tensor->data.f[i] = sensor_buffer[idx];
    }

    // Run inference
    unsigned long start_us = micros();
    TfLiteStatus invoke_status = interpreter->Invoke();
    unsigned long inference_us = micros() - start_us;

    if (invoke_status != kTfLiteOk) {
      Serial.println("ERROR: Invoke() failed!");
    } else {
      // Output results as JSON for the web interface to parse
      Serial.print("{\"t\":");
      Serial.print(millis());
      Serial.print(",\"latency_us\":");
      Serial.print(inference_us);

      {% if num_classes > 1 %}
      // Classification output
      Serial.print(",\"predictions\":[");
      int best_class = 0;
      float best_score = -1.0;
      for (int i = 0; i < NUM_CLASSES; i++) {
        float score = output_tensor->data.f[i];
        Serial.print(score, 4);
        if (i < NUM_CLASSES - 1) Serial.print(",");
        if (score > best_score) {
          best_score = score;
          best_class = i;
        }
      }
      Serial.print("],\"class\":");
      Serial.print(best_class);
      Serial.print(",\"confidence\":");
      Serial.print(best_score, 4);
      {% else %}
      // Regression output
      Serial.print(",\"value\":");
      Serial.print(output_tensor->data.f[0], 4);
      {% endif %}

      Serial.print(",\"raw\":");
      Serial.print(normalized, 4);
      Serial.println("}");
    }
  }

  delay(SAMPLE_RATE_MS);
}
