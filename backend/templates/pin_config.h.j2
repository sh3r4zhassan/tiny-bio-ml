/*
 * TinyBioML — Pin & Hardware Configuration
 * Board: {{ board_name }}
 * MCU: {{ mcu }}
 * Model: {{ model_name }}
 * Generated: {{ timestamp }}
 *
 * AUTO-GENERATED by TinyBioML platform.
 * Redeploy to change pin assignments.
 */

#ifndef TINYBIOML_PIN_CONFIG_H
#define TINYBIOML_PIN_CONFIG_H

// =============================================================
// Board & Model Identity
// =============================================================
#define TBML_BOARD         "{{ board_name }}"
#define TBML_MCU           "{{ mcu }}"
#define TBML_MODEL         "{{ model_name }}"

// =============================================================
// Serial Output
// =============================================================
#define TBML_BAUD          {{ serial_baud | default(115200) }}
#define TBML_JSON          1  // Always output JSON for web serial monitor

// =============================================================
// LED / Output Pins (active LOW on Nano 33 BLE)
// =============================================================
#define TBML_LED_BUILTIN   LED_BUILTIN
{% if led_class_0 is defined %}
#define TBML_LED_CLASS_0   {{ led_class_0 }}
#define TBML_LED_CLASS_1   {{ led_class_1 }}
#define TBML_LED_CLASS_2   {{ led_class_2 }}
{% if led_class_3 is defined %}
#define TBML_LED_CLASS_3   {{ led_class_3 }}
{% endif %}
{% else %}
// Default: use onboard RGB LEDs
#define TBML_LED_CLASS_0   LEDR
#define TBML_LED_CLASS_1   LEDG
#define TBML_LED_CLASS_2   LEDB
{% endif %}

// =============================================================
// Microphone Config
// =============================================================
{% if mic_use_default | default(true) %}
#define TBML_MIC_DEFAULT   1       // Use board's default PDM mic
{% else %}
#define TBML_MIC_DEFAULT   0
#define TBML_MIC_CLK       {{ mic_clk_pin }}
#define TBML_MIC_DATA      {{ mic_data_pin }}
{% endif %}
#define TBML_MIC_GAIN      {{ mic_gain | default(20) }}

{% for pin in extra_pins | default([]) %}
// {{ pin.label }}
#define TBML_{{ pin.name | upper }}  {{ pin.value }}
{% endfor %}

#endif  // TINYBIOML_PIN_CONFIG_H
