/*
 * TinyBioML — Hardware Configuration
 * Board: {{ board_name }}
 * MCU: {{ mcu }}
 * Model: {{ model_name }}
 * Generated: {{ timestamp }}
 *
 * AUTO-GENERATED — redeploy from TinyBioML to change.
 */

#ifndef TINYBIOML_PIN_CONFIG_H
#define TINYBIOML_PIN_CONFIG_H

// =============================================================
// Identity
// =============================================================
#define TBML_BOARD         "{{ board_name }}"
#define TBML_MCU           "{{ mcu }}"
#define TBML_MODEL         "{{ model_name }}"

// =============================================================
// Serial
// =============================================================
#define TBML_BAUD          {{ serial_baud | default(115200) }}
#define TBML_JSON          1

// =============================================================
// Sensor Input Configuration
// =============================================================
// Protocol: how the sensor communicates
//   0 = PDM (digital microphone, uses PDM library)
//   1 = ANALOG (analogRead on a pin)
//   2 = I2C (read bytes from an I2C address)
//   3 = SPI (read from SPI device)

#define TBML_SENSOR_PROTOCOL    {{ sensor_protocol }}

// Use board's default hardware for this sensor?
// 1 = yes (e.g., Nano 33 BLE's onboard PDM mic on default pins)
// 0 = no (custom pins specified below)
#define TBML_USE_DEFAULT        {{ 1 if use_default else 0 }}

{% if sensor_protocol == 0 %}
// --- PDM Microphone ---
#define TBML_MIC_CHANNELS       1
#define TBML_MIC_SAMPLE_RATE    16000
#define TBML_MIC_GAIN           {{ mic_gain | default(20) }}
{% if not use_default %}
#define TBML_PDM_CLK_PIN        {{ pdm_clk_pin }}
#define TBML_PDM_DATA_PIN       {{ pdm_data_pin }}
{% endif %}
{% endif %}

{% if sensor_protocol == 1 %}
// --- Analog Sensor ---
#define TBML_ANALOG_PIN         {{ analog_pin }}
#define TBML_ANALOG_SAMPLE_HZ   {{ analog_sample_hz | default(16000) }}
#define TBML_ANALOG_RESOLUTION  {{ analog_resolution | default(1023) }}
{% endif %}

{% if sensor_protocol == 2 %}
// --- I2C Sensor ---
#define TBML_I2C_ADDR           {{ i2c_address }}
#define TBML_I2C_SDA_PIN        {{ i2c_sda }}
#define TBML_I2C_SCL_PIN        {{ i2c_scl }}
#define TBML_I2C_REG            {{ i2c_register | default('0x00') }}
#define TBML_I2C_BYTES          {{ i2c_read_bytes | default(2) }}
{% endif %}

{% if sensor_protocol == 3 %}
// --- SPI Sensor ---
#define TBML_SPI_CS_PIN         {{ spi_cs_pin }}
#define TBML_SPI_SPEED          {{ spi_speed | default(1000000) }}
{% endif %}

// =============================================================
// Output LEDs
// =============================================================
#define TBML_LED_BUILTIN        LED_BUILTIN
{% if led_class_0 is defined %}
#define TBML_LED_CLASS_0        {{ led_class_0 }}
#define TBML_LED_CLASS_1        {{ led_class_1 }}
#define TBML_LED_CLASS_2        {{ led_class_2 }}
{% else %}
// Defaults for Nano 33 BLE
#define TBML_LED_CLASS_0        LEDR
#define TBML_LED_CLASS_1        LEDG
#define TBML_LED_CLASS_2        LEDB
{% endif %}

#endif  // TINYBIOML_PIN_CONFIG_H
