/*
 * TinyBioML Auto-Generated Firmware
 * Model: {{ model_name }}
 * Board: {{ board_name }}
 * Input: {{ input_source_label }}
 * Generated: {{ timestamp }}
 *
 * Generated by TinyBioML Platform
 * Customize by re-deploying from the platform with different pin settings.
 */

{% if input_source == 'pdm_microphone' %}
#include <PDM.h>
{% endif %}
{% if input_source == 'imu' %}
#include <Arduino_LSM9DS1.h>
{% endif %}
{% if input_source == 'i2c' %}
#include <Wire.h>
{% endif %}

#include <TensorFlowLite.h>
#include "tensorflow/lite/micro/all_ops_resolver.h"
#include "tensorflow/lite/micro/micro_error_reporter.h"
#include "tensorflow/lite/micro/micro_interpreter.h"
#include "tensorflow/lite/schema/schema_generated.h"

#include "model_data.h"

// =============================================================
// Configuration — auto-generated from TinyBioML deploy settings
// =============================================================
{% if input_source == 'analog' %}
#define SENSOR_PIN        {{ pin }}
{% elif input_source == 'digital' %}
#define SENSOR_PIN        {{ pin }}
{% endif %}
#define SAMPLE_RATE_MS    {{ sample_rate_ms }}
#define INPUT_SIZE        {{ input_size }}
#define NUM_CLASSES       {{ num_classes }}
#define TENSOR_ARENA_KB   {{ arena_size_kb }}

{% if class_labels %}
const char* CLASS_NAMES[NUM_CLASSES] = {
{% for label in class_labels %}
  "{{ label }}"{{ "," if not loop.last }}
{% endfor %}
};
{% endif %}

// =============================================================
// TFLite Micro
// =============================================================
namespace {
  tflite::ErrorReporter* error_reporter = nullptr;
  const tflite::Model* model = nullptr;
  tflite::MicroInterpreter* interpreter = nullptr;
  TfLiteTensor* input_tensor = nullptr;
  TfLiteTensor* output_tensor = nullptr;

  constexpr int kTensorArenaSize = TENSOR_ARENA_KB * 1024;
  alignas(16) uint8_t tensor_arena[kTensorArenaSize];
}

// =============================================================
// Sensor buffers
// =============================================================
float sensor_buffer[INPUT_SIZE];
int buffer_index = 0;
bool buffer_full = false;

{% if input_source == 'pdm_microphone' %}
// --- PDM Microphone ---
#define AUDIO_SAMPLE_RATE  16000
#define AUDIO_BUFFER_SIZE  16000  // 1 second
int16_t audioBuffer[AUDIO_BUFFER_SIZE];
volatile int samplesRead = 0;
volatile bool recordingDone = false;

void onPDMdata() {
  int bytesAvailable = PDM.available();
  int samplesToRead = bytesAvailable / 2;
  if (recordingDone) return;
  int remaining = AUDIO_BUFFER_SIZE - samplesRead;
  if (samplesToRead > remaining) samplesToRead = remaining;
  PDM.read(&audioBuffer[samplesRead], samplesToRead * 2);
  samplesRead += samplesToRead;
  if (samplesRead >= AUDIO_BUFFER_SIZE) recordingDone = true;
}
{% endif %}

{% if input_source == 'imu' %}
// --- IMU ---
// Reads accelerometer (ax, ay, az) and/or gyroscope (gx, gy, gz)
// Total 6 floats per sample, packed into input buffer
#define IMU_FEATURES_PER_SAMPLE  {{ imu_features }}  // 3=accel only, 6=accel+gyro
{% endif %}

// =============================================================
// Setup
// =============================================================
void setup() {
  Serial.begin(115200);
  while (!Serial) delay(10);

  Serial.println("{\"status\":\"boot\",\"msg\":\"TinyBioML Firmware\",\"model\":\"{{ model_name }}\"}");

  {% if input_source == 'analog' %}
  pinMode(SENSOR_PIN, INPUT);
  Serial.println("{\"status\":\"init\",\"msg\":\"Analog pin {{ pin }} configured\"}");
  {% elif input_source == 'digital' %}
  pinMode(SENSOR_PIN, INPUT);
  Serial.println("{\"status\":\"init\",\"msg\":\"Digital pin {{ pin }} configured\"}");
  {% elif input_source == 'pdm_microphone' %}
  PDM.onReceive(onPDMdata);
  if (!PDM.begin(1, AUDIO_SAMPLE_RATE)) {
    Serial.println("{\"status\":\"error\",\"msg\":\"PDM mic init failed\"}");
    while (1) delay(1000);
  }
  Serial.println("{\"status\":\"init\",\"msg\":\"PDM microphone active @ 16kHz\"}");
  {% elif input_source == 'imu' %}
  if (!IMU.begin()) {
    Serial.println("{\"status\":\"error\",\"msg\":\"IMU init failed\"}");
    while (1) delay(1000);
  }
  Serial.print("{\"status\":\"init\",\"msg\":\"IMU active @ ");
  Serial.print(IMU.accelerationSampleRate());
  Serial.println(" Hz\"}");
  {% elif input_source == 'i2c' %}
  Wire.begin();
  Serial.println("{\"status\":\"init\",\"msg\":\"I2C bus initialized\"}");
  {% endif %}

  // Load model
  static tflite::MicroErrorReporter micro_error_reporter;
  error_reporter = &micro_error_reporter;

  model = tflite::GetModel(model_data);
  if (model->version() != TFLITE_SCHEMA_VERSION) {
    Serial.println("{\"status\":\"error\",\"msg\":\"Model schema mismatch\"}");
    while (1) delay(1000);
  }

  static tflite::AllOpsResolver resolver;
  static tflite::MicroInterpreter static_interpreter(
    model, resolver, tensor_arena, kTensorArenaSize, error_reporter);
  interpreter = &static_interpreter;

  if (interpreter->AllocateTensors() != kTfLiteOk) {
    Serial.println("{\"status\":\"error\",\"msg\":\"AllocateTensors failed — increase TENSOR_ARENA_KB\"}");
    while (1) delay(1000);
  }

  input_tensor = interpreter->input(0);
  output_tensor = interpreter->output(0);

  Serial.print("{\"status\":\"ready\",\"msg\":\"Model loaded\",\"arena_used\":");
  Serial.print(interpreter->arena_used_bytes());
  {% if class_labels %}
  Serial.print(",\"classes\":[");
  for (int i = 0; i < NUM_CLASSES; i++) {
    Serial.print("\""); Serial.print(CLASS_NAMES[i]); Serial.print("\"");
    if (i < NUM_CLASSES - 1) Serial.print(",");
  }
  Serial.print("]");
  {% endif %}
  Serial.println("}");

  memset(sensor_buffer, 0, sizeof(sensor_buffer));
}

// =============================================================
// Read one sample from the configured input source
// =============================================================
{% if input_source == 'analog' %}
float readSample() {
  int raw = analogRead(SENSOR_PIN);
  return raw / {{ analog_max }}.0;  // Normalize to 0.0–1.0
}
{% elif input_source == 'digital' %}
float readSample() {
  return digitalRead(SENSOR_PIN) ? 1.0 : 0.0;
}
{% elif input_source == 'imu' %}
bool readIMUSample(float* out) {
  float ax, ay, az, gx, gy, gz;
  if (IMU.accelerationAvailable()) {
    IMU.readAcceleration(ax, ay, az);
    out[0] = ax; out[1] = ay; out[2] = az;
    {% if imu_features == 6 %}
    if (IMU.gyroscopeAvailable()) {
      IMU.readGyroscope(gx, gy, gz);
      out[3] = gx / 250.0; out[4] = gy / 250.0; out[5] = gz / 250.0;
    }
    {% endif %}
    return true;
  }
  return false;
}
{% elif input_source == 'i2c' %}
float readI2CSample() {
  // Generic I2C read — customize for your sensor
  Wire.requestFrom({{ i2c_address }}, 2);
  if (Wire.available() >= 2) {
    int16_t raw = (Wire.read() << 8) | Wire.read();
    return raw / 32768.0;
  }
  return 0.0;
}
{% endif %}

// =============================================================
// Main Loop
// =============================================================
void loop() {
{% if input_source == 'pdm_microphone' %}
  // --- Microphone: record 1s of audio, then process ---
  samplesRead = 0;
  recordingDone = false;
  while (!recordingDone) delay(1);

  // Copy audio into input tensor (normalize int16 → float)
  for (int i = 0; i < INPUT_SIZE && i < AUDIO_BUFFER_SIZE; i++) {
    {% if quantized %}
    // Int8 quantized model
    float val = audioBuffer[i] / 32768.0;
    int32_t q = (int32_t)roundf(val / input_tensor->params.scale) + input_tensor->params.zero_point;
    if (q < -128) q = -128;
    if (q > 127) q = 127;
    input_tensor->data.int8[i] = (int8_t)q;
    {% else %}
    input_tensor->data.f[i] = audioBuffer[i] / 32768.0;
    {% endif %}
  }

{% elif input_source == 'imu' %}
  // --- IMU: fill buffer with N samples ---
  int idx = 0;
  while (idx < INPUT_SIZE) {
    float sample[IMU_FEATURES_PER_SAMPLE];
    if (readIMUSample(sample)) {
      for (int f = 0; f < IMU_FEATURES_PER_SAMPLE && idx < INPUT_SIZE; f++) {
        sensor_buffer[idx++] = sample[f];
      }
    }
    delay(SAMPLE_RATE_MS);
  }

  // Copy to input tensor
  for (int i = 0; i < INPUT_SIZE; i++) {
    {% if quantized %}
    int32_t q = (int32_t)roundf(sensor_buffer[i] / input_tensor->params.scale) + input_tensor->params.zero_point;
    if (q < -128) q = -128;
    if (q > 127) q = 127;
    input_tensor->data.int8[i] = (int8_t)q;
    {% else %}
    input_tensor->data.f[i] = sensor_buffer[i];
    {% endif %}
  }

{% else %}
  // --- Analog / Digital / I2C: fill circular buffer ---
  {% if input_source == 'i2c' %}
  float val = readI2CSample();
  {% else %}
  float val = readSample();
  {% endif %}

  sensor_buffer[buffer_index] = val;
  buffer_index++;
  if (buffer_index >= INPUT_SIZE) {
    buffer_full = true;
    buffer_index = 0;
  }

  if (!buffer_full) {
    delay(SAMPLE_RATE_MS);
    return;  // Wait until buffer is full
  }

  // Copy circular buffer to input tensor
  for (int i = 0; i < INPUT_SIZE; i++) {
    int idx = (buffer_index + i) % INPUT_SIZE;
    {% if quantized %}
    int32_t q = (int32_t)roundf(sensor_buffer[idx] / input_tensor->params.scale) + input_tensor->params.zero_point;
    if (q < -128) q = -128;
    if (q > 127) q = 127;
    input_tensor->data.int8[i] = (int8_t)q;
    {% else %}
    input_tensor->data.f[i] = sensor_buffer[idx];
    {% endif %}
  }
{% endif %}

  // --- Run inference ---
  unsigned long t0 = micros();
  TfLiteStatus status = interpreter->Invoke();
  unsigned long inference_us = micros() - t0;

  if (status != kTfLiteOk) {
    Serial.println("{\"status\":\"error\",\"msg\":\"Inference failed\"}");
    {% if input_source != 'analog' and input_source != 'digital' and input_source != 'i2c' %}
    delay(100);
    {% else %}
    delay(SAMPLE_RATE_MS);
    {% endif %}
    return;
  }

  // --- Output results as JSON ---
  Serial.print("{\"t\":");
  Serial.print(millis());
  Serial.print(",\"infer_us\":");
  Serial.print(inference_us);

  {% if num_classes > 1 %}
  // Classification
  int bestClass = 0;
  float bestScore = -1e9;
  Serial.print(",\"scores\":[");
  for (int i = 0; i < NUM_CLASSES; i++) {
    {% if quantized %}
    float score = (output_tensor->data.int8[i] - output_tensor->params.zero_point) * output_tensor->params.scale;
    {% else %}
    float score = output_tensor->data.f[i];
    {% endif %}
    Serial.print(score, 4);
    if (i < NUM_CLASSES - 1) Serial.print(",");
    if (score > bestScore) { bestScore = score; bestClass = i; }
  }
  Serial.print("],\"class\":");
  Serial.print(bestClass);
  {% if class_labels %}
  Serial.print(",\"label\":\"");
  Serial.print(CLASS_NAMES[bestClass]);
  Serial.print("\"");
  {% endif %}
  Serial.print(",\"confidence\":");
  Serial.print(bestScore, 4);
  {% else %}
  // Regression
  {% if quantized %}
  float value = (output_tensor->data.int8[0] - output_tensor->params.zero_point) * output_tensor->params.scale;
  {% else %}
  float value = output_tensor->data.f[0];
  {% endif %}
  Serial.print(",\"value\":");
  Serial.print(value, 4);
  {% endif %}

  Serial.println("}");

  {% if input_source == 'pdm_microphone' %}
  delay(100);  // Brief pause between recordings
  {% elif input_source == 'imu' %}
  // IMU loop is self-paced by sample collection
  {% else %}
  delay(SAMPLE_RATE_MS);
  {% endif %}
}
